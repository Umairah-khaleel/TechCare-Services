<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F3E5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/transparent"
        android:padding="10dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#4A148C"
            android:contentDescription="@string/back_button_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/title_add_new_service"
            android:textColor="#4A148C"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_service_name"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <EditText
                android:id="@+id/etServiceName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/hint_service_name"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="15dp"
                android:inputType="text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_service_category"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="15dp"
                android:background="@drawable/rounded_edittext"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_repair_fee"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <EditText
                android:id="@+id/etServiceFee"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/hint_repair_fee"
                android:inputType="number"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_estimated_time"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <EditText
                android:id="@+id/etEstimateTime"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/hint_estimated_time"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="15dp"
                android:inputType="text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_image_link"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <EditText
                android:id="@+id/etImageUrl"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/hint_image_link"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="15dp"
                android:inputType="textUri"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_service_description"
                android:textColor="#4A148C"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"/>
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="@string/hint_service_description"
                android:gravity="top"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:inputType="textMultiLine"/>

            <Button
                android:id="@+id/btnUploadService"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="@string/btn_add_service"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#7B1FA2"/>

            <Button
                android:id="@+id/btnViewAllServices"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_view_all_services"
                android:textColor="#7B1FA2"
                android:textStyle="bold"
                app:strokeColor="#7B1FA2"
                app:strokeWidth="2dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>