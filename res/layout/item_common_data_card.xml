<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/rounded_card_purple"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/tvServiceType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_service_type"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4A148C"/>

    <TextView
        android:id="@+id/tvMainTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_device_model"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#6A1B9A"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/tvSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_customer_info"
        android:textSize="15sp"
        android:textColor="#4A148C"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvDetailInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_booking_details"
        android:textSize="14sp"
        android:textColor="#7B1FA2"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_address"
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="#C2185B"
        android:layout_marginTop="6dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_status"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="#FFFFFF"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/btnUpdate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_update_status"
        android:backgroundTint="#4A148C"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvCreatedAt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#000000"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"/>
</LinearLayout>
